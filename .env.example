# Copy to .env and adjust as needed. Every var here is optional — the app
# runs with sane local defaults (app/config.py::Settings) if .env is absent.

# Path to the SQLite database file (created on first run).
DATABASE_PATH=./data/agent_service.db

# Scales the runner's simulated sleep durations only; recorded/reported
# durations remain unscaled. Set to 100 in tests for a fast suite.
SIM_SPEED=1.0

# OTLP endpoint the app exports traces/metrics to. Defaults to the local
# Collector (see docker-compose.yml). Leave as-is unless bypassing the
# Collector entirely.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Resource attributes attached to every span/metric.
OTEL_SERVICE_NAME=agent-service
OTEL_SERVICE_VERSION=0.1.0

# How long an Idempotency-Key stays valid before a repeat request with the
# same key is treated as a fresh one.
IDEMPOTENCY_KEY_TTL_HOURS=24

# --- Grafana Cloud (optional) ---
# Collector always emits to its local `debug` exporter regardless of these
# (docker-compose.yml supplies harmless defaults for both if unset), so the
# system runs fully without a Grafana Cloud account. Set both to see traces
# and metrics in Grafana Cloud instead:
#   GRAFANA_CLOUD_OTLP_ENDPOINT: your Tempo/Mimir OTLP gateway URL, e.g.
#     https://otlp-gateway-<region>.grafana.net/otlp
#   GRAFANA_CLOUD_OTLP_AUTH_HEADER: base64("<instance-id>:<api-key>")
# GRAFANA_CLOUD_OTLP_ENDPOINT=
# GRAFANA_CLOUD_OTLP_AUTH_HEADER=
